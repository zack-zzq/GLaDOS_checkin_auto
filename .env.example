# ===== 必填 =====
# GLaDOS Cookie，多账号用 & 分隔
GLADOS_COOKIE=your_cookie_here

# ===== 可选 =====
# GLaDOS 域名（不含协议），默认 glados.one
# GLADOS_DOMAIN=glados.one

# 每日签到时间（HH:MM 格式，24小时制），默认 09:00
# CHECKIN_TIME=09:00

# 时区，默认 Asia/Shanghai
# TZ=Asia/Shanghai

# ===== Gotify 推送（可选）=====
# Gotify 服务地址
# GOTIFY_URL=https://gotify.example.com

# Gotify 应用 Token
# GOTIFY_TOKEN=your_gotify_token

# Gotify 消息优先级（1-10），默认 5
# GOTIFY_PRIORITY=5

# Gotify 消息标题格式，{status} 会被替换为 成功/失败
# GOTIFY_TITLE_FORMAT=GLaDOS签到 - {status}
